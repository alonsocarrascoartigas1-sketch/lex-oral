# ─── CONFIGURACIÓN LEX ORAL BACKEND ───────────────────────────────────────────
# Copia este archivo como .env y completa los valores

# Tu API Key de Anthropic (consola.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXX

# Puerto donde corre el servidor (Railway/Render lo asignan automáticamente)
PORT=3000

# URL del frontend (para CORS). En desarrollo usa *
# En producción pon la URL exacta: https://lexoral.tudominio.com
FRONTEND_URL=*

# Límite de mensajes por usuario por hora (anti-abuso)
RATE_LIMIT_PER_HOUR=60

# Máximo de tokens por respuesta de Claude
MAX_TOKENS=700

# Modelo de Claude a usar
CLAUDE_MODEL=claude-sonnet-4-20250514
